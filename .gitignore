# Zephyr tools may use this to run the needed python tools part of toolchain
.venv/
venv/

# External appears after west update and may contain zephyr install
external/

# Build artefacts generated by west
**/build*/

# Segger Ozone creates temporary .user files when opening debug session.
# These are system-dependent and not needed for configuration of debug sessions on other PCs
*.user

# Any future CI might have to use .env files in the workflows
# It is useful to have this measure in already
.env

# VScode creates lots of user-specific configs which when merged might cause conflicts
# As these configs are most of the time not portable
.vscode/